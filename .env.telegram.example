# Telegram Bot Configuration
# Para ativar notificações Telegram, preencha as variáveis abaixo

# Token do bot (obtido via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=8529208973:AAEjcSBY_aNJ0tCfs0uyFnxFyLo7w_DbeH4

# ID do chat (seu ID pessoal ou de um grupo)
# Para obter: envie uma mensagem para o bot e acesse:
# https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
# Procure por "chat":{"id":123456789
TELEGRAM_CHAT_ID=

# Exemplo de uso:
# 1. Crie um bot com @BotFather no Telegram
# 2. Copie o token para TELEGRAM_BOT_TOKEN
# 3. Envie /start para o bot
# 4. Acesse a URL acima para pegar seu CHAT_ID
# 5. Cole o CHAT_ID aqui
# 6. Reinicie o daemon: pkill -f intelligent_daemon.py && cd /home/ubuntu/arbitrage-dashboard && nohup python3 intelligent_daemon.py > intelligent_daemon.log 2>&1 &
