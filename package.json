{
  "name": "egreja-daemon",
  "version": "2.0.0",
  "description": "Egreja Investment AI + Nina Voice Agent",
  "main": "intelligent_daemon_mysql.py",
  "scripts": {
    "start": "bash start-all.sh",
    "api": "node api_signals.js",
    "voice-agent": "node voice_agent_realtime.js",
    "voice-agent:dev": "nodemon voice_agent_realtime.js",
    "daemon": "python3 intelligent_daemon_mysql.py",
