    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
