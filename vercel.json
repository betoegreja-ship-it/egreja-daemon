{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "static",
  "installCommand": "",
  "rewrites": [
    { "source": "/strategies/:path*", "destination": "/strategies/:path*" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/health", "destination": "/health" },
    { "source": "/signals", "destination": "/signals" },
    { "source": "/stats", "destination": "/stats" },
    { "source": "/trades/:path*", "destination": "/trades/:path*" },
    { "source": "/long-horizon/:path*", "destination": "/long-horizon/:path*" },
    { "source": "/brain/:path*", "destination": "/brain/:path*" },
    { "source": "/prices/:path*", "destination": "/prices/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
